# ===========================================
# 测试环境配置文件 (.env.testing)
# ===========================================

# 应用配置
APP_NAME=Hello-FastApi
APP_ENV=testing
DEBUG=true
SECRET_KEY=test-secret-key-for-testing-only
API_VERSION=v1

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置 (SQLite 测试数据库，存放在 sql 目录)
DATABASE_URL=sqlite+aiosqlite:///./sql/test.db

# Redis 配置 (使用独立的测试数据库)
REDIS_URL=redis://localhost:6379/1

# JWT 配置
JWT_SECRET_KEY=test-jwt-secret-key-for-testing-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=1

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8848

# 限流配置
RATE_LIMIT_TIMES=1000
RATE_LIMIT_SECONDS=60

# 日志配置
LOG_LEVEL=DEBUG
