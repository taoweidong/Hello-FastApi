# ===========================================
# Hello-FastApi 环境变量配置模板
# ===========================================
#
# 使用说明：
# 1. 复制此文件为 .env（用于本地开发）
#    cp .env.example .env
#
# 2. 或者使用特定环境的配置文件：
#    - .env.development  (开发环境)
#    - .env.production   (生产环境)
#    - .env.testing      (测试环境)
#
# 3. 配置加载优先级：
#    系统环境变量 > .env.{APP_ENV} > .env > 默认值
#
# 4. 设置运行环境：
#    export APP_ENV=development  # Linux/Mac
#    set APP_ENV=development     # Windows
# ===========================================

# ============ 应用配置 ============
APP_NAME=Hello-FastApi
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-must-be-at-least-32-characters-long
API_VERSION=v1

# ============ 服务器配置 ============
HOST=0.0.0.0
PORT=8000

# ============ 数据库配置 ============
# SQLite (开发环境推荐，数据库文件存放在 sql 目录)
DATABASE_URL=sqlite+aiosqlite:///./sql/dev.db

# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hello_fastapi

# MySQL (可选)
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/hello_fastapi

# ============ Redis 配置 ============
REDIS_URL=redis://localhost:6379/0

# ============ JWT 配置 ============
JWT_SECRET_KEY=your-jwt-secret-key-must-be-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ CORS 配置 ============
# 多个源用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============ 限流配置 ============
RATE_LIMIT_TIMES=100
RATE_LIMIT_SECONDS=60

# ============ 日志配置 ============
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
